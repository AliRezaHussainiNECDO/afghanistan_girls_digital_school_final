    "test": "tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "typescript": "^5.6.3",
    "wrangler": "^4.113.0",
    "tsx": "^4.22.4"
  },
  "dependencies": {
    "hono": "^4.6.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260721.1": true
  }
}
