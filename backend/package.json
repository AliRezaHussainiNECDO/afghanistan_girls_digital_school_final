{
  "name": "afghan-girls-school-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply afghan_girls_school_db --remote",
    "db:migrate:local": "wrangler d1 migrations apply afghan_girls_school_db --local",
