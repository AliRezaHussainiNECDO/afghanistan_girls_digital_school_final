# ═══════════════════════════════════════════════════════════════════════════
# .dev.vars.example — الگوی رازهای محلی برای توسعهٔ روی کامپیوتر خودتان.
#
# نحوهٔ استفاده:
#   1) این فایل را کپی کنید:  cp .dev.vars.example .dev.vars
#   2) مقادیر واقعی را در فایل تازهٔ .dev.vars بگذارید (نه اینجا).
#   3) `.dev.vars` از قبل در .gitignore هست — هرگز کامیت نمی‌شود؛ همین فایل
#      نمونه (.dev.vars.example) بدون مقدار واقعی امن است و باید کامیت شود.
#
# در Production این مقادیر با `wrangler secret put <NAME>` تنظیم می‌شوند —
# نه در wrangler.toml و نه در هیچ فایلی داخل مخزن Git (جزئیات هر کدام هم به‌
# صورت کامنت در wrangler.toml کنار همان بخش مربوطه توضیح داده شده‌اند).
# ═══════════════════════════════════════════════════════════════════════════

# اجباری — بدون این، هیچ توکنی صادر/تأیید نمی‌شود (احراز هویت کاملاً از کار می‌افتد).
JWT_SECRET=replace-with-a-long-random-string

# اختیاری — هرکدام نبود، فقط همان قابلیت مشخص را غیرفعال می‌کند؛ بقیهٔ اپ کار می‌کند.
AI_PROVIDER_KEY=
AZURE_TTS_KEY=
GEMINI_API_KEY=
CF_STREAM_TOKEN=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
RESEND_API_KEY=
GROQ_API_KEY=
CERT_SIGNING_PRIVATE_KEY=
COLUMN_ENCRYPTION_KEY=
